<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Team Directory</title>
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --paper: #FFFCF5;
    --paper-band: #FFCF95;
    --surface: #FFFFFF;
    --rule: #C99A5B;
    --rule-faint: #E8D2AC;
    --ink: #3A2E1F;
    --ink-soft: #7A6A52;
    --accent: #7A1F2B;
  }

  body { font-family: Georgia, 'Times New Roman', serif; background: var(--paper); color: var(--ink); min-height: 100vh; }

  header {
    background: var(--paper-band);
    border-bottom: 3px double var(--rule);
    padding: 28px 20px 22px;
    text-align: center;
  }
  header h1 { font-size: 22px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; }
  header p { margin-top: 5px; font-size: 12px; font-style: italic; color: var(--ink); letter-spacing: 0.4px; }

  main { max-width: 480px; margin: 0 auto; padding: 24px 16px 60px; }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 2px solid var(--rule);
    padding-bottom: 8px;
    margin-bottom: 20px;
    font-size: 11px;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .cards { display: flex; flex-direction: column; gap: 12px; }

  .card {
    background: var(--surface);
    border: 1px solid var(--rule-faint);
    border-top: 3px solid var(--rule);
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .card:hover { border-top-color: var(--accent); background: #FFFEFA; }
  .card:active { background: #FFF5E6; }

  .avatar {
    width: 42px; height: 42px;
    border-radius: 50%;
    background: var(--paper-band);
    border: 1px solid var(--rule);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
    flex-shrink: 0;
    letter-spacing: 0.5px;
  }

  .card-info { flex: 1; min-width: 0; }
  .card-num { font-size: 10px; color: var(--ink-soft); letter-spacing: 0.5px; margin-bottom: 2px; }
  .card-name { font-size: 17px; font-weight: 700; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .card-role { font-size: 12px; color: var(--ink-soft); font-style: italic; margin-top: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .card-arrow { color: var(--rule); font-size: 16px; flex-shrink: 0; }

  /* Backdrop */
  .backdrop {
    display: none;
    position: fixed; inset: 0; z-index: 100;
    background: rgba(58,46,31,0.5);
    align-items: flex-end;
    justify-content: center;
  }
  .backdrop.open { display: flex; }

  /* Bottom sheet */
  .sheet {
    background: var(--surface);
    border: 1px solid var(--rule-faint);
    border-bottom: none;
    border-radius: 14px 14px 0 0;
    width: 100%;
    max-width: 480px;
    max-height: 88vh;
    overflow-y: auto;
    animation: slideUp 0.25s ease-out;
  }
  @keyframes slideUp {
    from { transform: translateY(100%); }
    to   { transform: translateY(0); }
  }

  .sheet-handle { display: flex; justify-content: center; padding: 10px 0 0; }
  .sheet-handle span { width: 36px; height: 4px; background: var(--rule-faint); border-radius: 99px; }

  .sheet-header {
    background: var(--paper-band);
    border-bottom: 3px double var(--rule);
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .sheet-avatar {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: var(--surface);
    border: 2px solid var(--rule);
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    font-weight: 700;
    color: var(--accent);
    flex-shrink: 0;
  }
  .sheet-header-info { flex: 1; min-width: 0; }
  .sheet-name { font-size: 20px; font-weight: 700; color: var(--ink); }
  .sheet-role { font-size: 13px; font-style: italic; color: var(--ink-soft); margin-top: 2px; }

  .close-btn {
    background: var(--surface);
    border: 1px solid var(--rule);
    width: 30px; height: 30px;
    font-size: 14px;
    cursor: pointer;
    color: var(--ink);
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .close-btn:hover { background: var(--accent); color: #fff; border-color: var(--accent); }

  .sheet-body { padding: 4px 0 16px; }

  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    padding: 12px 18px;
    border-bottom: 1px dashed var(--rule-faint);
  }
  .detail-row:last-child { border-bottom: none; }
  .detail-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.7px; color: var(--ink-soft); flex-shrink: 0; min-width: 80px; padding-top: 1px; }
  .detail-value { font-size: 13px; color: var(--ink); text-align: right; word-break: break-word; line-height: 1.5; }
  .detail-value a { color: var(--accent); text-decoration: none; border-bottom: 1px solid var(--accent); }
  .detail-value a:hover { opacity: 0.75; }

  @media (prefers-reduced-motion: reduce) {
    .sheet { animation: none; }
  }
</style>
</head>
<body>

<header>
  <h1>Team Directory</h1>
  <p>Register of Employees</p>
</header>

<main>
  <div class="meta">
    <span>Startup Employee Register</span>
    <span id="countLabel"></span>
  </div>
  <div class="cards" id="cards"></div>
</main>

<div class="backdrop" id="backdrop">
  <div class="sheet" id="sheet">
    <div class="sheet-handle"><span></span></div>
    <div class="sheet-header">
      <div class="sheet-avatar" id="sheetAvatar"></div>
      <div class="sheet-header-info">
        <div class="sheet-name" id="sheetName"></div>
        <div class="sheet-role" id="sheetRole"></div>
      </div>
      <button class="close-btn" id="closeBtn" aria-label="Close">&#10005;</button>
    </div>
    <div class="sheet-body" id="sheetBody"></div>
  </div>
</div>

<script>
const employees = [
  {name:"Biswajit Pradhan",position:"Full Stack Developer",college:"Government College of Engineering, Keonjhar",department:"Computer Science & Engineering", regNumber:"2301104065",mobile:"+91 88959 80998",email:"basantbiswa04@gmail.com",dateOfJoining:"09-05-2025",linkedin:"www.linkedin.com/in/biswapulan"},
  {name:"Smruti Somyashree Parida",position:"Frontend Developer",college:"Government College of Engineering, Keonjhar",department:""Computer Science & Engineering,regNumber:"2301104112",mobile:"+91 63715 64626",email:"smrutiparida40@gmail.com",dateOfJoining:"09-05-2025",linkedin:"https://www.linkedin.com/in/smruti-somyashree-6386b532b/"},
{name:"Asish Kumar Rout",position:"Designer & Social Media Manager",college:"Government College of Engineering, Keonjhar",department:""Computer Science & Engineering,regNumber:"2301104058",mobile:"+91 78490 62862",email:"akrout9999@gmail.com",dateOfJoining:"16 Feb 2026",linkedin:"https://www.linkedin.com/in/asish-kumar-rout-0262102b2/"},  
{name:"Sanskruti Ram",position:"Volunteer",college:"Government College of Engineering, Keonjhar",department:"Electrical Engineering",regNumber:"2501104131",mobile:"9337905908",email:"sanskrutiram268@gmail.com",dateOfJoining:"18 Jun 2026",linkedin:"https://www.linkedin.com/in/sanskruti-ram-b01962416?utm_source=share_via&utm_content=profile&utm_medium=member_android"},

{name:"Satya Prakash Nayak",position:"Volunteer",college:"Government College of Engineering, Keonjhar",department:"Electrical Engineering",regNumber:"2401104188",mobile:"9777721616",email:"satyaprakashnayak789@gmail.com",dateOfJoining:"18 Jun 2026",linkedin:""},

{name:"Abhay Kumar",position:"Volunteer",college:"Government College of Engineering, Keonjhar",department:"Computer Science & Engineering",regNumber:"2401104062",mobile:"7008490419",email:"abhayakumar869@gmail.com",dateOfJoining:"18 Jun 2026",linkedin:""},

{name:"JOGESWAR BARIK",position:"Volunteer",college:"Government College of Engineering, Keonjhar",department:"Mining Engineering",regNumber:"2501104252",mobile:"9692034132",email:"jogeswarjee01@gmail.com",dateOfJoining:"18 Jun 2026",linkedin:""},

{name:"Mahes Behera",position:"Volunteer",college:"Government College of Engineering, Keonjhar",department:"Computer Science & Engineering",regNumber:"2401104089",mobile:"6370378084",email:"mahes4021@gmail.com",dateOfJoining:"18 Jun 2026",linkedin:"https://www.linkedin.com/in/mahesbehera?utm_source=share_via&utm_content=profile&utm_medium=member_android"},

{name:"Ashutosh Agrawal",position:"Volunteer",college:"Government College Of Engineering, Kalahandi",department:"Computer Science And Engineering",regNumber:"2401110038",mobile:"9827330036",email:"ashutoshagrawal1508@gmail.com",dateOfJoining:"18 Jun 2026",linkedin:"https://www.linkedin.com/posts/ashutosh-agrawal-cse_internship-bput-bputnotes-share-7473325904199458816-0dMU/?utm_source=social_share_send&utm_medium=android_app&rcm=ACoAAGdjPuYBoB4mNRPj0wExpYCXv5kdV6YS1uo&utm_campaign=copy_link"},

{name:"Dibya Prakash Pradhan",position:"Volunteer",college:"Government College of Engineering, Keonjhar",department:"Metallurgical and Materials Engineering",regNumber:"2501104409",mobile:"7608016920",email:"dibyaisop@gmail.com",dateOfJoining:"18 Jun 2026",linkedin:""},
];

const esc = s => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };
const initials = n => n.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();

const cardsEl = document.getElementById('cards');
const backdrop = document.getElementById('backdrop');
const sheetAvatar = document.getElementById('sheetAvatar');
const sheetName = document.getElementById('sheetName');
const sheetRole = document.getElementById('sheetRole');
const sheetBody = document.getElementById('sheetBody');
const closeBtn = document.getElementById('closeBtn');
document.getElementById('countLabel').textContent = employees.length + ' entries';

employees.forEach((emp, i) => {
  const card = document.createElement('div');
  card.className = 'card';
  card.setAttribute('tabindex', '0');
  card.setAttribute('role', 'button');
  card.setAttribute('aria-label', emp.name + ', ' + emp.position);
  card.innerHTML = `
    <div class="avatar">${esc(initials(emp.name))}</div>
    <div class="card-info">
      <div class="card-num">Entry No. ${String(i+1).padStart(2,'0')} &nbsp;·&nbsp; ${esc(emp.regNumber)}</div>
      <div class="card-name">${esc(emp.name)}</div>
      <div class="card-role">${esc(emp.position)}</div>
    </div>
    <div class="card-arrow">›</div>
  `;
  const open = () => openSheet(emp);
  card.addEventListener('click', open);
  card.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }});
  cardsEl.appendChild(card);
});

function row(label, value, isHtml = false) {
  return `<div class="detail-row">
    <div class="detail-label">${esc(label)}</div>
    <div class="detail-value">${isHtml ? value : esc(value)}</div>
  </div>`;
}

function openSheet(emp) {
  sheetAvatar.textContent = initials(emp.name);
  sheetName.textContent = emp.name;
  sheetRole.textContent = emp.position + ' · ' + emp.department;
  sheetBody.innerHTML =
    row('Reg. No.', emp.regNumber) +
    row('Department', emp.department) +
    row('Joined', emp.dateOfJoining) +
    row('College', emp.college) +
    row('Mobile', emp.mobile) +
    row('Email', `<a href="mailto:${esc(emp.email)}">${esc(emp.email)}</a>`, true) +
    row('LinkedIn', `<a href="${esc(emp.linkedin)}" target="_blank" rel="noopener">View Profile →</a>`, true);
  backdrop.classList.add('open');
  document.body.style.overflow = 'hidden';
  closeBtn.focus();
}

function closeSheet() {
  backdrop.classList.remove('open');
  document.body.style.overflow = '';
}

closeBtn.addEventListener('click', closeSheet);
backdrop.addEventListener('click', e => { if (e.target === backdrop) closeSheet(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeSheet(); });

let startY = 0;
const sheet = document.getElementById('sheet');
sheet.addEventListener('touchstart', e => { startY = e.touches[0].clientY; }, { passive: true });
sheet.addEventListener('touchend', e => {
  if (e.changedTouches[0].clientY - startY > 80 && sheet.scrollTop === 0) closeSheet();
}, { passive: true });
</script>

</body>
</html>
